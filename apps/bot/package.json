{
  "name": "@agent-connect/bot",
  "version": "0.1.0",
  "type": "module",
  "description": "Agent Connect TypeScript bot and management API",
  "main": "./dist/src/agent-connect/main.js",
  "types": "./dist/src/agent-connect/main.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/agent-connect/main.d.ts",
      "default": "./dist/src/agent-connect/main.js"
    },
    "./hook": {
      "types": "./dist/src/agent-connect/hook.d.ts",
      "default": "./dist/src/agent-connect/hook.js"
    },
    "./service": {
      "types": "./dist/src/agent-connect/service.d.ts",
      "default": "./dist/src/agent-connect/service.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "tsx src/agent-connect/main.ts",
    "start": "node dist/src/agent-connect/main.js",
    "hook:install": "pnpm build && node dist/src/agent-connect/main.js hook --install",
    "build": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\" && tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test:ts": "vitest run",
    "prepack": "pnpm --filter @agent-connect/telegramify-markdown build && pnpm build"
  },
  "dependencies": {
    "better-sqlite3": "^12.10.0",
    "dotenv": "^16.4.7",
    "fastify": "^5.8.5",
    "grammy": "^1.43.0",
    "sharp": "^0.34.5",
    "@agent-connect/telegramify-markdown": "workspace:*",
    "undici": "^8.3.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13"
  }
}
