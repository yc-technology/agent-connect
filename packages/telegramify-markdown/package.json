{
  "name": "telegramify-markdown",
  "version": "1.1.5",
  "private": true,
  "type": "module",
  "description": "Convert Markdown to Telegram text, MessageEntity objects, and MarkdownV2",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test:ts": "vitest run"
  },
  "dependencies": {
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.5"
  },
  "devDependencies": {
    "tsdown": "^0.17.0"
  }
}
