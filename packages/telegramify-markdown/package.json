{
  "name": "@yc-tech/telegramify-markdown",
  "version": "0.1.1",
  "type": "module",
  "description": "Convert Markdown to Telegram HTML / text / MessageEntity objects / MarkdownV2",
  "keywords": [
    "telegram",
    "markdown",
    "html",
    "telegramify",
    "messageentity",
    "markdownv2"
  ],
  "license": "MIT",
  "author": "Django <six.django@gmail.com>",
  "homepage": "https://github.com/yc-technology/agent-connect/tree/main/packages/telegramify-markdown#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yc-technology/agent-connect.git",
    "directory": "packages/telegramify-markdown"
  },
  "bugs": {
    "url": "https://github.com/yc-technology/agent-connect/issues"
  },
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test:ts": "vitest run",
    "prepack": "pnpm build"
  },
  "dependencies": {
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.5"
  },
  "devDependencies": {
    "tsdown": "^0.17.0"
  }
}
