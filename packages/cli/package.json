{
  "name": "@yc-tech/agent-connect-cli",
  "version": "0.3.11",
  "type": "module",
  "description": "Agent Connect command line — bridges Telegram Forum topics to Claude Code / Codex sessions in tmux",
  "keywords": [
    "telegram",
    "claude",
    "claude-code",
    "codex",
    "tmux",
    "agent",
    "cli"
  ],
  "license": "MIT",
  "author": "Django <six.django@gmail.com>",
  "homepage": "https://github.com/yc-technology/agent-connect#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yc-technology/agent-connect.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/yc-technology/agent-connect/issues"
  },
  "bin": {
    "agc": "./dist/src/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "pnpm --filter @yc-tech/telegramify-markdown build && pnpm --filter @yc-tech/agent-connect-bot build && tsx src/index.ts start",
    "start": "node dist/src/index.js start",
    "hook:install": "pnpm build && node dist/src/index.js hook --install",
    "build": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\" && tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepack": "pnpm --filter @yc-tech/telegramify-markdown build && pnpm --filter @yc-tech/agent-connect-bot build && pnpm build"
  },
  "dependencies": {
    "@yc-tech/agent-connect-bot": "workspace:*",
    "undici": "^8.3.0"
  }
}
