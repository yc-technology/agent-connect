# Telegram Bot Token (required)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Allowed user IDs (comma-separated, required)
ALLOWED_USERS=123456789,987654321

# Tmux session name (optional, defaults to "agent-connect")
TMUX_SESSION_NAME=agent-connect

# Claude command to run in new windows (optional, defaults to "claude --permission-mode bypassPermissions")
CLAUDE_COMMAND=claude --permission-mode bypassPermissions

# Codex command to run in new windows (optional, defaults to "codex --yolo")
CODEX_COMMAND=codex --yolo

# Monitor polling interval in seconds (optional, defaults to 2.0)
MONITOR_POLL_INTERVAL=2.0

# Deleted-topic probe interval in seconds (optional, defaults to 60.0; set 0 to disable)
AGENT_CONNECT_TOPIC_PROBE_INTERVAL=60.0

# Show detailed thinking/tool/local command messages (optional, defaults to false)
AGENT_CONNECT_SHOW_INTERMEDIATE_MESSAGES=false

# HTTP proxy for Telegram/OpenAI requests (optional)
# Common local VPN/proxy clients expose an HTTP proxy on 7890, 7897, or 1087.
# export HTTP_PROXY=http://127.0.0.1:7890/
# export HTTPS_PROXY=http://127.0.0.1:7890/
# export http_proxy=http://127.0.0.1:7890/
# export https_proxy=http://127.0.0.1:7890/
# export NO_PROXY=127.0.0.1,localhost
# export no_proxy=127.0.0.1,localhost
